# CONTAIA PRO — Variables de Entorno

# Servidor
NODE_ENV=development
PORT=3000
APP_NAME=CONTAIA PRO
APP_VERSION=1.0.0

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT — Access Token
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=1h

# JWT — Refresh Token
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

# JWT — Recuperación de contraseña
JWT_RESET_EXPIRES_IN=15m

# Cookies (true en producción con HTTPS)
COOKIE_SECURE=false

# Base de datos (módulos futuros)
DATABASE_URL=mysql+pymysql://contaia:contaia_secret@localhost:3306/contaia_db

# Logging
LOG_LEVEL=info

# Servicio de IA externo
AI_SERVICE_URL=http://localhost:5001
