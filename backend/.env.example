# CONTAIA PRO — Backend Environment Variables
# Copiar a .env y ajustar valores

APP_NAME=CONTAIA PRO
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=mysql+pymysql://contaia:contaia_secret@localhost:3306/contaia_db

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security (Módulo 2)
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
