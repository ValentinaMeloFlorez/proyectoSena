{
  "name": "contaia-pro",
  "version": "1.0.0",
  "description": "CONTAIA PRO — Sistema Web de Gestión Empresarial y Contable con IA",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently --kill-others-on-fail --names \"backend,frontend\" --prefix-colors \"blue,green\" \"nodemon server.js\" \"npm run dev --prefix frontend\"",
    "dev:backend": "nodemon server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "test": "node --test",
    "test-db": "node test-db.js"
  },
  "keywords": [
    "contaia",
    "express",
    "mvc",
    "accounting"
  ],
  "author": "CONTAIA PRO Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "chart.js": "^4.4.7",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.3",
    "pdfkit": "^0.15.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
